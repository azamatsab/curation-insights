# Required for ingestion (insight extraction) and answer synthesis.
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides (defaults shown). Embeddings are LOCAL, so retrieval and the
# vector store work without any API key — only extraction + synthesis need it.
# EXTRACT_MODEL=claude-haiku-4-5
# SYNTH_MODEL=claude-haiku-4-5
# EXTRACT_BATCH=20
# BUDGET_USD=2.50
